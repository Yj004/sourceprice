# Google Sheets (required for API server)
GOOGLE_SHEET_ID=your-google-sheet-id

# Local dev: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# Vercel / serverless: paste full minified JSON (use instead of file path)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

PORT=3002
BACKEND_CORS_ORIGINS=http://localhost:5173

# Frontend (optional — defaults to /api via Vite proxy)
VITE_API_BASE=/api

# Auth — first super admin seeded when user-manage tab is empty
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_BOOTSTRAP_PASSWORD=change-me
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email — Category Team Cost alerts (brand routing in server/emailService.js)
EMAIL_FROM=sourceprice@avaipl.com
EMAIL_ENABLED=true

# SMTP (required to actually send emails)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username@avaipl.com
SMTP_PASS=your-smtp-app-password
